model Loan {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  start_date      DateTime    @default(now())
  driver_id       String      @db.ObjectId
  amount          Float       @default(0)
  due_amount      Float       @default(0)
  interest_rate   Float       @default(0)
  bank_account_no String
  loan_id         String      @db.ObjectId
  status          ELoanStatus @default(PENDING)

  driver User          @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  loan   AvailableLoan @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@map("loans")
}

enum ELoanStatus {
  PENDING
  ACCEPTED
  REJECTED
  PAID
}
