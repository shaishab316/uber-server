model Loan {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  start_date DateTime    @default(now())
  user_id    String      @db.ObjectId
  loan_id    String      @db.ObjectId
  status     ELoanStatus @default(PENDING)

  name                String
  amount              Float
  contact             String // email or phone number
  problem             String
  bank_account_number String
  document            String // link to document image or pdf

  user User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  loan AvailableLoan @relation(fields: [loan_id], references: [id], onDelete: Cascade)

  @@map("loans")
}

enum ELoanStatus {
  PENDING
  ACCEPTED
  REJECTED
  PAID
}
