model NewsFeed {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  last_edited DateTime  @default(now()) @updatedAt
  title       String
  content     String
  body        String?
  image       String
  role        EUserRole @default(USER)
  category    String

  @@map("news_feeds")
}

enum ENewsFeedCategory {
  MORE_WAY_TO_USE
  SAVE_EVERYONE
  NEWS_AND_PROMOTIONS
}
