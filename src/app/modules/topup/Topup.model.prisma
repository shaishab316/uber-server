model Topup {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  requested_at DateTime @default(now())

  user_id String?

  amount Int //? in cents

  completed_at DateTime?
  is_completed Boolean   @default(false)

  provider ETopupProvider

  provider_metadata Json? //? if completed, this will contain the provider's response

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([user_id, is_completed])
  @@index([is_completed, requested_at])
  @@map("topups")
}

enum ETopupProvider {
  AZUL
}
