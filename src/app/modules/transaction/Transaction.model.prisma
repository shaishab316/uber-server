model Transaction {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  stripe_transaction_id String?
  azul_order_id         String?
  user_id               String?          @db.ObjectId
  driver_id             String?          @db.ObjectId
  amount                Float
  type                  ETransactionType @default(TOPUP)
  payment_method        String           @default("unknown")

  user   User?  @relation("UserTransaction", fields: [user_id], references: [id], onDelete: SetNull)
  driver User?  @relation("DriverTransaction", fields: [driver_id], references: [id], onDelete: SetNull)
  Trip   Trip[]

  @@map("transactions")
}

enum ETransactionType {
  TOPUP
  EXPENSE
  WITHDRAW
  EARNED
}
